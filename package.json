{
  "name": "remote-flashlight",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm start",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server -- --watch\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}