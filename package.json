{
  "name": "remote-flashlight",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm --prefix client run build",
    "dev": "npm run build && concurrently \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:client": "npm --prefix client run dev",
    "dev:worker": "wrangler dev",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "check": "npm --prefix client run lint && npm run build && wrangler deploy --dry-run"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "wrangler": "^4.0.0"
  }
}
